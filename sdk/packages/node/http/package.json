{
  "name": "@iii-dev/http",
  "version": "0.19.0",
  "private": false,
  "publishConfig": { "access": "public" },
  "type": "module",
  "author": "III",
  "license": "Apache-2.0",
  "description": "HTTP primitives shared across iii SDKs.",
  "keywords": ["iii", "http"],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
