// on every page except the landing page, whose footer adds the get-started
// CTA block above these same columns (see landing/sections/11-footer.html).
// Colors ride each page's design tokens, so the footer follows the surface
// theme.
import Logo from './blog/Logo.astro'
import '../styles/site-footer.css'
---

